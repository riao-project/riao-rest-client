{
	"name": "@riao/rest-client",
	"version": "1.2.0",
	"description": "",
	"author": "riao-project",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"prepare": "npm run build",
		"preview": "vite preview",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint . --fix && prettier --write .",
		"lint:check": "prettier --check . && eslint .",
		"test": "npm run lint && npm run typecheck && npm run test:run",
		"test:ci": "npm run lint:check && npm run typecheck && npm run test:run",
		"test:dev": "vitest --ui --coverage",
		"test:run": "vitest run --coverage"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.8.2"
	},
	"dependencies": {
		"@riao/rest-contract": "^1.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@riao/cli": "^3.0.1",
		"@riao/dbal": "^3.8.0",
		"@riao/rest": "^2.1.3",
		"@riao/sqlite": "^3.4.0",
		"@types/node": "^22.19.17",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitest/coverage-v8": "^4.1.2",
		"@vitest/ui": "^4.1.2",
		"eslint": "^10.1.0",
		"fast-glob": "^3.3.3",
		"globals": "^17.6.0",
		"prettier": "^3.8.1",
		"prettier-plugin-brace-style": "^0.10.1",
		"terser": "^5.46.1",
		"ts-node": "^10.9.2",
		"ts-tiny-log": "^1.1.1",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.9",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.1.2"
	},
	"keywords": [],
	"main": "./dist/src/index.cjs",
	"module": "./dist/src/index.mjs",
	"types": "./dist/src/index.d.ts",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.mjs",
			"require": "./dist/src/index.cjs",
			"default": "./dist/src/index.mjs"
		},
		"./*": {
			"types": "./dist/src/*/index.d.ts",
			"import": "./dist/src/*/index.mjs",
			"require": "./dist/src/*/index.cjs",
			"default": "./dist/src/*/index.mjs"
		}
	},
	"files": [
		"dist"
	]
}
